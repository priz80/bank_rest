<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="002-create-card-table" author="gigacode">
        <createTable tableName="cards">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="card_number" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>

            <column name="card_holder_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="expiry_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="balance" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="cvv" type="VARCHAR(4)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="cards"
            baseColumnNames="user_id"
            constraintName="fk_card_user"
            referencedTableName="users"
            referencedColumnNames="id"
            onDelete="CASCADE"/>

        <createIndex tableName="cards" indexName="idx_card_user">
            <column name="user_id"/>
        </createIndex>
        <createIndex tableName="cards" indexName="idx_card_number">
            <column name="card_number"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>